# Optional: override API URL (e.g. http://192.168.1.10:3000 for a physical device)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Supabase (public anon key — menu list fetch)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Stripe Payment Sheet (requires dev build: npx expo run:ios / run:android — not Expo Go)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Voice + AI streaming use the backend — ensure it is running with OPENAI_API_KEY and ASSEMBLYAI_API_KEY set.
